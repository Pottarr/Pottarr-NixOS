# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=/home/pottarr/.config/i3blocks/$BLOCK_NAME
separator_block_width=15
markup=none

# Volume indicator
#
# The first parameter sets the step (and units to display)
# The second parameter overrides the mixer selection
# See the script for details.

# [volume]
# LABEL=♪ 
# LABEL=VOL 
# interval=once
# signal=10
# STEP=5%
#MIXER=[determined automatically]
#SCONTROL=[determined automatically]
#NATURAL_MAPPING=0

# Memory usage
#
# The type defaults to "mem" if the instance is not specified.
# [memory]
# label=MEM
# separator=false
# interval=30
#
# [memory]
# label=SWAP
# instance=swap
# separator=false
# interval=30

[disk]
label=  
interval=30

[numlock]
interval=1
signal=13

[capslock]
interval=1
signal=11

[keyboard-layout]
interval=1

[display-menu]
interval=once

[screenshot]
interval=once

[mic]
interval=1
signal=12

[volume]
interval=1
signal=10

[tailscale]
interval=10

[network]
interval=10

[battery]
interval=10

[date]
interval=1

[time]
command=date '+%H:%M:%S'
interval=1

[power-menu]
interval=once


